{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true
  },
  "include": [
    "client/**/*.ts",
    "tests/**/*.ts",
    "migrations/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "target"
  ]
}
